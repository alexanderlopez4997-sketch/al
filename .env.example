# Copy to .env (git-ignored) and fill in real values to enable `--email`
# and/or `--discord`.

# --- Gmail (--email) ---
# Generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the account).
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Optional: send to a different inbox than GMAIL_ADDRESS.
# GMAIL_TO=someone-else@example.com

# --- Discord (--discord) ---
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# --- Market data / alt-data feeds (web_server.py, quant_engine.py) ---
# All optional: each feed degrades gracefully when its key is missing.
# Massive: quotes, exchange reference data, SIP tape, and news sentiment.
# Both names are read (some modules use one, some the other) — set MASSIVE_KEY
# and you're covered everywhere.
MASSIVE_KEY=your_massive_api_key
MASSIVE_API_KEY=your_massive_api_key
# Finnhub: recs, insider trades, fallback news sentiment.
FINNHUB_KEY=your_finnhub_key
# Alpha Vantage: fundamentals, professionally-scored news sentiment.
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
# Quiver Quant: congressional trading, dark pool data.
QUIVER_API_TOKEN=your_quiver_token
# Alpaca: after-hours quotes, order flow.
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
